# --- OPENSAVEPIDLMRU ---
Write-Host "`nOPENSAVEPIDLMRU (arquivos abertos/salvos):" -ForegroundColor Yellow
Write-Host "--------------------------------------------------------------------"

$systemProps = @("Count","Length","LongLength","Rank","SyncRoot","IsReadOnly","IsFixedSize","IsSynchronized","MRUListEx","PSPath","PSParentPath","PSChildName","PSDrive","PSProvider")

$regPaths = @(
    "HKCU:\Software\Microsoft\Windows\CurrentVersion\Explorer\ComDlg32\OpenSavePidlMRU\exe",
    "HKCU:\Software\Microsoft\Windows\CurrentVersion\Explorer\ComDlg32\OpenSavePidlMRU\jfif",
    "HKCU:\Software\Microsoft\Windows\CurrentVersion\Explorer\ComDlg32\OpenSavePidlMRU\*"
)

foreach($rp in $regPaths){
    $label = $rp.Split("\")[-1]
    Write-Host "`n  [$label]" -ForegroundColor Cyan
    $regQueryPath = $rp -replace "HKCU:\\","HKCU\"
    try{
        $rawOutput = reg query $regQueryPath 2>&1
        if($LASTEXITCODE -ne 0 -or $rawOutput -match "nao foi possivel|cannot find|error"){
            Write-Host "  Limpo" -ForegroundColor Green
            continue
        }
        $lines = $rawOutput | Where-Object {
            $_ -match "REG_BINARY" -and $_ -notmatch ($systemProps -join "|")
        }
        if($lines.Count -gt 0){
            Write-Host "  RASTROS: $($lines.Count) entrada(s)" -ForegroundColor Red
            foreach($line in $lines){
                $parts = $line.Trim() -split "\s{2,}"
                $entryName = $parts[0]
                try{
                    $prop = (Get-ItemProperty -Path $rp -ErrorAction Stop).$entryName
                    if($prop){
                        $bytes = [byte[]]$prop
                        $text = [System.Text.Encoding]::Unicode.GetString($bytes) -replace '[^\x20-\x7E]',''
                        $text = $text.Trim()
                        if($text.Length -gt 3){
                            Write-Host "  -> $text" -ForegroundColor Red
                        }else{
                            Write-Host "  -> [entrada $entryName - binario]" -ForegroundColor DarkRed
                        }
                    }
                }catch{
                    Write-Host "  -> [entrada $entryName - ilegivel]" -ForegroundColor DarkRed
                }
            }
        }else{
            Write-Host "  Limpo" -ForegroundColor Green
        }
    }catch{
        Write-Host "  Erro ao verificar: $_" -ForegroundColor DarkYellow
    }
}

