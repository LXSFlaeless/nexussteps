$regPathPf = "HKLM:\SYSTEM\CurrentControlSet\Control\Session Manager\Memory Management\PrefetchParameters"
try{
    $currentValue = Get-ItemPropertyValue -Path $regPathPf -Name EnablePrefetcher -ErrorAction Stop
    if($currentValue -ne 3){
