Show-Section "RECENTDOCS (exe / lnk / rar / zip / dll / ahk / bat / jar)" "Yellow"
$allowedExt = @("exe","lnk","rar","zip","dll","ahk","bat","json","jar","7z","msi")
try{
    $rdBase = "HKCU:\SOFTWARE\Microsoft\Windows\CurrentVersion\Explorer\RecentDocs"
    $subKeys = Get-ChildItem $rdBase -ErrorAction Stop
    $rdFound = $false
    foreach($sk in $subKeys){
        $ext = $sk.PSChildName.ToLower().TrimStart(".")
        if($ext -notin $allowedExt){ continue }
        $vals = Get-ItemProperty -Path $sk.PSPath -ErrorAction SilentlyContinue
        $props = $vals.PSObject.Properties | Where-Object { $_.Name -notlike "PS*" -and $_.Name -ne "MRUListEx" }
        $extEntries = @()
        foreach($p in $props){
            try{
                $bytes = [byte[]]$p.Value
                $text = [System.Text.Encoding]::Unicode.GetString($bytes) -replace '[^\x20-\x7E]',''
                $text = $text.Trim()
                if($text.Length -gt 3 -and $text -match "\w"){ $extEntries += $text }
            }catch{}
        }
        if($extEntries.Count -gt 0){
            Write-Host ""
            Write-Host "    [$($sk.PSChildName)] - $($extEntries.Count) entrada(s)" -ForegroundColor Cyan
            Write-Host "    -------------------------------------------------------" -ForegroundColor DarkCyan
            $extEntries | %{
                if($_ -match $suspectExePattern){
                    Write-Host "    [!] $_" -ForegroundColor Red
                }else{
                    Write-Host "    -> $_" -ForegroundColor DarkGray
                }
            }
            $rdFound = $true
        }
    }
    if(-not $rdFound){ Write-Host "    Nenhum documento relevante encontrado" -ForegroundColor Green }
}catch{ Write-Host "    Chave nao existe (Limpo)" -ForegroundColor Green }

