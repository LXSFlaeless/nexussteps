    }elseif($bootStr -match "autocheck autochk"){
        Write-Host "    BootExecute: OK (padrao Windows)" -ForegroundColor Green
    }else{
        Write-Host "    [!] BootExecute MODIFICADO - verifique manualmente!" -ForegroundColor Red
    }
}catch{ Write-Host "    Erro ao verificar Session Manager" -ForegroundColor DarkYellow }

# --- PRINT MONITORS (DLLs persistentes via spooler) ---
Show-Section "PRINT MONITORS (DLLs persistentes via Spooler)" "Yellow"
try{
    $pm = Get-ChildItem "HKLM:\SYSTEM\CurrentControlSet\Control\Print\Monitors" -ErrorAction Stop
    $defaultMonitors = @("BJ Language Monitor","Local Port","Microsoft Shared Fax Monitor","Standard TCP/IP Port","USB Monitor","WSD Port")
    $pmFound = $false
    $pm | %{
        if($_.PSChildName -notin $defaultMonitors){
            Write-Host "    [!] Monitor nao padrao: $($_.PSChildName)" -ForegroundColor Red
            $pmFound = $true
        }
    }
    if(-not $pmFound){ Write-Host "    Apenas monitores padrao encontrados" -ForegroundColor Green }
}catch{ Write-Host "    Erro ao verificar Print Monitors" -ForegroundColor DarkYellow }

# --- SHARED DLLS (DLLs compartilhadas suspeitas) ---
Show-Section "SHARED DLLS (DLLs suspeitas registradas)" "Yellow"
try{
    $sdll = Get-ItemProperty "HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\SharedDLLs" -ErrorAction Stop
    $props = $sdll.PSObject.Properties | Where-Object { $_.Name -notlike "PS*" -and $_.Name -match $cheatPattern }
    if($props.Count -gt 0){
        Write-Host "    [!] DLLs suspeitas:" -ForegroundColor Red
        $props | %{ Write-Host "    -> $($_.Name)" -ForegroundColor DarkRed }
    }else{ Write-Host "    Nenhuma DLL suspeita encontrada" -ForegroundColor Green }
}catch{ Write-Host "    Erro ao verificar SharedDLLs" -ForegroundColor DarkYellow }

# --- ACTIVE SETUP (persistencia via componentes) ---
Show-Section "ACTIVE SETUP (Persistencia via Installed Components)" "Yellow"
try{
    $as = Get-ChildItem "HKLM:\SOFTWARE\Microsoft\Active Setup\Installed Components" -ErrorAction Stop
    $asFound = $false
    $as | %{
        $vals = Get-ItemProperty $_.PSPath -ErrorAction SilentlyContinue
        if($vals.StubPath -match $cheatPattern){
            Write-Host "    [!] $($_.PSChildName): $($vals.StubPath)" -ForegroundColor Red
            $asFound = $true
        }
    }
    if(-not $asFound){ Write-Host "    Nenhum componente suspeito" -ForegroundColor Green }
}catch{ Write-Host "    Erro ao verificar Active Setup" -ForegroundColor DarkYellow }

Write-Host ""
Write-Host "  ================================================================" -ForegroundColor DarkCyan
Write-Host "    NEXUS T1 STEPS - FINALIZADO COM SUCESSO" -ForegroundColor Cyan
Write-Host "  ================================================================" -ForegroundColor DarkCyan
Write-Host ""
Start-Sleep -Seconds 1
Write-Host "  Pressione ENTER para fechar..." -ForegroundColor Yellow
while ($true) {
    if ([System.Console]::KeyAvailable) {
        $key = [System.Console]::ReadKey($true)
        if ($key.Key -eq "Enter") { break }
    }
    Start-Sleep -Milliseconds 100
}
exit
