Show-Section "SHIMCACHE / AppCompatCache (Historico de executaveis)" "Yellow"
try{
    $shimPath = "HKLM:\SYSTEM\CurrentControlSet\Control\Session Manager\AppCompatCache"
    $shim = Get-ItemProperty -Path $shimPath -ErrorAction Stop
    $cacheData = $shim.AppCompatCache
    if($cacheData){
        $bytes = [byte[]]$cacheData
        # Extrair todas as strings Unicode legíveis do binário (caminhos de exe)
        $allText = [System.Text.Encoding]::Unicode.GetString($bytes)
        # Pegar sequências que parecem caminhos de arquivo (contém \ e .exe)
        $paths = [regex]::Matches($allText, '[A-Za-z]:\\[^\x00-\x1F"*<>|]{4,260}') | %{ $_.Value.Trim() }
        $paths = $paths | Where-Object { $_ -match "\.exe" } | Select-Object -Unique

        $shimFound = $false
        $paths | %{
            if($_ -match "(?i)(oldui|newui|matcha|valex|xeno|loader|updater)" -and $_ -notmatch "(?i)(google|lghub|onedrive|directxdatabase)"){
                Write-Host "    [!] $_" -ForegroundColor Red
                $shimFound = $true
            }
        }
        if(-not $shimFound){ Write-Host "    Nenhum suspeito encontrado no ShimCache" -ForegroundColor Green }
    }else{ Write-Host "    Dados nao encontrados" -ForegroundColor DarkYellow }
}catch{ Write-Host "    Chave nao existe (Limpo)" -ForegroundColor Green }

